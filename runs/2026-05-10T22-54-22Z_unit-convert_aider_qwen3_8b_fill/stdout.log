import sys

def main():
    # Parse input
    if len(sys.argv) != 2:
        print("error: missing expression")
        sys.exit(1)
    expr = sys.argv[1]

    # Split into terms and target_unit
    parts = expr.split(' to ')
    if len(parts) != 2:
        print("error: invalid expression")
        sys.exit(1)
    terms_str, target_unit = parts
    terms = terms_str.split()

    # Check if target_unit is valid
    if not is_valid_unit(target_unit):
        print(f"error: invalid target unit {target_unit}")
        sys.exit(1)

    # Parse each term into value and unit
    parsed_terms = []
    for term in terms:
        if not term:
            print("error: invalid term")
            sys.exit(1)
        parts = term.split()
        if len(parts) != 2:
            print("error: invalid term")
            sys.exit(1)
        value_str, unit = parts
        try:
            value = float(value_str)
        except ValueError:
            print(f"error: invalid value {value_str}")
            sys.exit(1)
        parsed_terms.append( (value, unit.lower()) )

    # Determine the category of the target unit
    target_category = get_unit_category(target_unit.lower())
    if target_category is None:
        print(f"error: invalid target unit {target_unit}")
        sys.exit(1)

    # Check if all terms are in the same category as target_unit
    for value, unit in parsed_terms:
        category = get_unit_category(unit)
        if category != target_category:
            print(f"error: incompatible units {unit} and {target_category}")
            sys.exit(1)

    # Sum the values in their category's base unit
    total = 0.0
    for value, unit in parsed_terms:
        base_value = convert_to_base_unit(value, unit, target_category)
        total += base_value

    # Convert total to target_unit's value
    if target_category == 'temperature':
        result = convert_temperature(total, target_unit)
    else:
        result = convert_to_unit(total, target_unit)

    # Format output
    print(f"{result:.4f} {target_unit}")

