def crc32_ieee(data: bytes) -> int:
    crc = 0xFFFFFFFF
    for byte in data:
        crc ^= byte << 24
        for _ in range(8):
            if crc & 0x80000000:
                crc = (crc << 1) ^ 0xEDB88320
            else:
                crc <<= 1
    return crc ^ 0xFFFFFFFF

def crc16_xmodem(data: bytes) -> int:
    crc = 0x0000
    for byte in data:
        crc ^= byte << 8
        for _ in range(8):
            if crc & 0x8000:
                crc = (crc << 1) ^ 0x1021
            else:
                crc <<= 1
    return crc

if __name__ == "__main__":
    import sys

    if len(sys.argv) != 3 or sys.argv[1] not in ('crc32', 'crc16'):
        print("Usage: python3 crc.py <crc32|crc16> <ascii_string>")
        sys.exit(1)

    algorithm = sys.argv[1]
    input_str = sys.argv[2].encode()

    if algorithm == "crc32":
        result = crc32_ieee(input_str)
        print(f"{result:08x}")
    elif algorithm == "crc16":
        result = crc16_xmodem(input_str)
        print(f"{result:04x}")
```

