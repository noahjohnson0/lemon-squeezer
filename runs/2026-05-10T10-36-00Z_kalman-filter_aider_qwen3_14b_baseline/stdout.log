    result[1][1] = A[1][0] * B[0][1] + A[1][1] * B[1][1]
    return result

def _matrix_inv(self, A):
    # Invert a 2x2 matrix A
    det = A[0][0] * A[1][1] - A[0][1] * A[1][0]
    if det == 0:
        raise ValueError("Matrix is singular")
    inv = [
        [A[1][1] / det, -A[0][1] / det],
        [-A[1][0] / det, A[0][0] / det]
    ]
    return inv

