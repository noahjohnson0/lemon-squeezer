import re

import numpy as np

from fractions import Fraction

from math import gcd

from functools import reduce



def balance(equation: str) -> tuple[list[int], list[int]]:

    """

    Take an unbalanced equation string like "H2 + O2 -> H2O".

    Return (lhs_coefficients, rhs_coefficients) as lists of POSITIVE integers

    in the smallest-integer form.



    Example:

        balance("H2 + O2 -> H2O") returns ([2, 1], [2])

        balance("CH4 + O2 -> CO2 + H2O") returns ([1, 2], [1, 2])

    """

    # Parse the equation

    if '->' not in equation:

        raise ValueError("Invalid equation format")

    

    lhs_str, rhs_str = equation.split('->')

    lhs_str = lhs_str.strip()

    rhs_str = rhs_str.strip()

    

    # Parse reactants and products

    lhs_reactants = [r.strip() for r in lhs_str.split('+')]

    rhs_products = [r.strip() for r in rhs_str.split('+')]

    

    # Get all unique elements

    elements = set()

    all_compounds = lhs_reactants + rhs_products

    

    # Parse compounds to extract elements and their counts

    compound_elements = []

    for compound in all_compounds:

        elements_in_compound = parse_compound(compound)

        compound_elements.append(elements_in_compound)

        elements.update(elements_in_compound.keys())

    

    # Sort elements alphabetically

    elements = sorted(list(elements))

    

    # Build matrix of element counts

    matrix = []

    for element in elements:

        row = []

        # Left side (reactants) - positive coefficients

        for i, compound in enumerate(lhs_reactants):

            if element in compound_elements[i]:

                row.append(compound_elements[i][element])

            else:

                row.append(0)

        # Right side (products) - negative coefficients

        for i, compound in enumerate(rhs_products):

            if element in compound_elements[i + len(lhs_reactants)]:

                row.append(-compound_elements[i + len(lhs_reactants)][element])

            else:

                row.append(0)

        matrix.append(row)

    

    # Convert to numpy array

    A = np.array(matrix, dtype=int)

    

    # Find null space using SVD

    _, s, vh = np.linalg.svd(A)

    

    # Find the smallest singular value and corresponding vector

    tol = 1e-10

    rank = np.sum(s > tol)

    null_space = vh[rank:].T

    

    if null_space.size == 0:

        raise ValueError("Equation is not balanceable")

    

    # Get a solution vector from the null space

    solution = null_space[:, 0]

    

    # Scale to get integer coefficients

    # Find the least common multiple of denominators

    fractions = [Fraction(x).limit_denominator(1000000) for x in solution]

    denominators = [f.denominator for f in fractions]

    lcm_den = reduce(lambda a, b: a * b // gcd(a, b), denominators)

    

    # Scale the solution

    scaled_solution = [int(f * lcm_den) for f in fractions]

    

    # Ensure all coefficients are positive

    if all(x >= 0 for x in scaled_solution):

        # All positive, we're good

        pass

    elif all(x <= 0 for x in scaled_solution):

        # All negative, flip signs

        scaled_solution = [-x for x in scaled_solution]

    else:

        # Mixed signs - find a valid solution

        # Try to find a positive solution by scaling

        # Find the minimum positive coefficient

        positive_coeffs = [x for x in scaled_solution if x > 0]

        if not positive_coeffs:

            raise ValueError("Equation is not balanceable")

        

        # Scale to make all coefficients positive

        min_positive = min(positive_coeffs)

        scaled_solution = [int(x * min_positive) for x in scaled_solution]

        

        # Ensure all are positive

        if any(x <= 0 for x in scaled_solution):

            # Try a different approach

            # Find the smallest positive coefficient and scale to make it 1

            positive_indices = [i for i, x in enumerate(scaled_solution) if x > 
0]

            if not positive_indices:

                raise ValueError("Equation is not balanceable")

            

            min_positive_idx = positive_indices[0]

            min_positive_val = scaled_solution[min_positive_idx]

            

            # Scale all by min_positive_val

            scaled_solution = [int(x * min_positive_val) for x in 
scaled_solution]

    

    # Separate into lhs and rhs coefficients

    lhs_coeffs = scaled_solution[:len(lhs_reactants)]

    rhs_coeffs = scaled_solution[len(lhs_reactants):]

    

    # Reduce to smallest integers

    all_coeffs = lhs_coeffs + rhs_coeffs

    if not all_coeffs:

        raise ValueError("No coefficients found")

    

    # Find GCD of all coefficients

    common_gcd = reduce(gcd, [abs(x) for x in all_coeffs if x != 0])

    

    # If GCD is 1, we're already in smallest form

    if common_gcd > 1:

        lhs_coeffs = [x // common_gcd for x in lhs_coeffs]

        rhs_coeffs = [x // common_gcd for x in rhs_coeffs]

    

    # Ensure all coefficients are positive

    if any(x <= 0 for x in lhs_coeffs + rhs_coeffs):

        raise ValueError("Equation is not balanceable")

    

    return (lhs_coeffs, rhs_coeffs)



def parse_compound(compound):

    """Parse a compound string and return a dictionary of element counts."""

    elements = {}

    

    # Find all element occurrences with their counts

    # This pattern matches elements (capital letter followed by optional 
lowercase)

    # and optional numbers after them

    pattern = r'([A-Z][a-z]*)(\d*)'

    

    # Handle parentheses

    while '(' in compound:

        # Find the first closing parenthesis

        start = compound.rfind('(')

        end = compound.find(')', start)

        if end == -1:

            raise ValueError("Unbalanced parentheses")

        

        # Extract the content inside parentheses

        inner = compound[start+1:end]

        

        # Find the multiplier after the closing parenthesis

        multiplier = 1

        if end + 1 < len(compound) and compound[end+1].isdigit():

            # Find the full number

            num_start = end + 1

            while num_start < len(compound) and compound[num_start].isdigit():

                num_start += 1

            multiplier = int(compound[end+1:num_start])

            compound = compound[:start] + inner * multiplier + 
compound[num_start:]

        else:

            compound = compound[:start] + inner + compound[end+1:]

    

    # Now parse the compound

    matches = re.findall(pattern, compound)

    

    for element, count in matches:

        count = int(count) if count else 1

        if element in elements:

            elements[element] += count

        else:

            elements[element] = count

    

    return elements

