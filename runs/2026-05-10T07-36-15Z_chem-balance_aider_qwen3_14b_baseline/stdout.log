def parse_formula(formula):
    stack = []
    current = {}
    i = 0
    while i < len(formula):
        if formula[i].isupper():
            # Start of an element
            element = formula[i]
            i += 1
            while i < len(formula) and formula[i].islower():
                element += formula[i]
                i += 1
            # Now, parse the number after the element
            count = 0
            while i < len(formula) and formula[i].isdigit():
                count = count * 10 + int(formula[i])
                i += 1
            if count == 0:
                count = 1
            current[element] = current.get(element, 0) + count
        elif formula[i] == '(':
            # Push current to stack and reset
            stack.append((current, 1))
            current = {}
            i += 1
        elif formula[i] == ')':
            # Pop from stack and multiply
            prev_current, multiplier = stack.pop()
            # Multiply current by multiplier and add to prev_current
            for elem, cnt in current.items():
                prev_current[elem] = prev_current.get(elem, 0) + cnt * 
multiplier
            current = prev_current
            # Now, parse the number after the ')'
            count = 0
            while i < len(formula) and formula[i].isdigit():
                count = count * 10 + int(formula[i])
                i += 1
            if count == 0:
                count = 1
            # Multiply all elements in current by count
            for elem in current:
                current[elem] *= count
            i += 1
        else:
            i += 1
    return current

