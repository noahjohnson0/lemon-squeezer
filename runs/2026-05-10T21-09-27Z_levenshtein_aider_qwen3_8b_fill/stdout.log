            else:
                dp[i][j] = 1 + min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1])
    # Backtrack to find the path
    current_i, current_j = m, n
    operations = []
    while current_i > 0 or current_j > 0:
        if current_i == 0:
