backend/main.py:

```
from fastapi import FastAPI
import subprocess
import json
import re

app = FastAPI()

def get_wifi_info():
    try:
        result = subprocess.run(
            ["/System/Library/PrivateFrameworks/Apple80211.framework/Versions/Cu
rrent/Resources/airport", "-I"],
            capture_output=True,
            text=True,
            check=True
        )
        output = result.stdout
        info = {}
        for line in output.splitlines():
            if ':' in line:
                key, value = line.split(':', 1)
                info[key.strip()] = value.strip()
        # Map keys to desired fields
        ssid = info.get('SSID')
        bssid = info.get('BSSID')
        rssi = int(info.get('agrCtlRSSI', '0'))
        channel = info.get('channel')
        tx_rate = info.get('agrCtlTxRate')
        security = info.get('security')
        return {
            "ssid": ssid,
            "bssid": bssid,
            "rssi": rssi,
            "channel": channel,
            "tx_rate": tx_rate,
            "security": security
        }
    except Exception as e:
        return {"error": str(e)}

@app.get("/api/wifi")
async def wifi():
    return get_wifi_info()
```

