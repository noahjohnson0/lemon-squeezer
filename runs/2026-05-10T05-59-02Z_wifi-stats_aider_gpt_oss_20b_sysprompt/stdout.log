import React from 'react';

interface WifiInfo {
  ssid: string;
  bssid: string;
  rssi: number;
  channel: string;
  tx_rate: string;
  security: string;
}

interface Props {
  info: WifiInfo;
}

export default function WifiCard({ info }: Props) {
  return (
