        </li>
        <li>
          <strong>Channel:</strong> {info.channel || 'N/A'}
        </li>
        <li>
          <strong>TX Rate:</strong> {info.tx_rate || 'N/A'} Mbps
        </li>
        <li>
          <strong>Security:</strong> {info.security || 'N/A'}
        </li>
      </ul>
    </div>
  );
}
