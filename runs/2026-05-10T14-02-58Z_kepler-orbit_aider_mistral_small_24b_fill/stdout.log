range(4))



    y = [x0, y0, vx0, vy0]

    t = 0.0

    while t < t_end:

        y = runge_kutta_4(tuple(y), t, dt)

        t += dt



    return tuple(y)



def total_energy(x: float, y: float, vx: float, vy: float) -> float:

    """Specific orbital energy E = ½(vx² + vy²) - GM/r where r = √(x² + y²) and 
GM=1.0."""

    r = math.sqrt(x**2 + y**2)

    return 0.5 * (vx**2 + vy**2) - 1 / r

