def matmul(A, B):
    # Check if the number of columns of A matches the number of rows of B
    if len(A[0]) != len(B):
        raise ValueError("Shape mismatch")
    n = len(A)
    m = len(B[0])
    p = len(A[0])
    result = [[0.0 for _ in range(m)] for _ in range(n)]
    for i in range(n):
        for j in range(m):
            for k in range(p):
                result[i][j] += A[i][k] * B[k][j]
    return result

