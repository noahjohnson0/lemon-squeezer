def score(password: str) -> tuple[int, list[str]]:
    blocklist = ["password", "123456", "12345678", "qwerty", "letmein", "admin",
"welcome", "iloveyou", "monkey", "dragon"]
    reasons = []
    score_val = 0

    # Check blocklist and length
    if not password or password.lower() in blocklist:
        if not password:
            reasons.append("too-short")
        else:
            reasons.append("in-blocklist")
        return (0, reasons)

    length = len(password)
    if length < 8:
        reasons.append("too-short")
        return (0, reasons)

    # Check character classes
    classes = set()
    for c in password:
        if c.islower():
            classes.add("lower")
        elif c.isupper():
            classes.add("upper")
        elif c.isdigit():
            classes.add("digit")
        else:
            classes.add("symbol")
    class_count = len(classes)

    # Determine score based on length and classes
    if length >= 8 and length <= 11:
        if class_count < 3:
            score_val = 1
            # Add missing classes
            for cls in ["lower", "upper", "digit", "symbol"]:
                if cls not in classes:
                    reasons.append(f"missing-{cls}")
        else:
            score_val = 2
    elif length >= 12:
        if class_count < 3:
            score_val = 2
            # Add missing classes
            for cls in ["lower", "upper", "digit", "symbol"]:
                if cls not in classes:
                    reasons.append(f"missing-{cls}")
        else:
            # Check for repeats
            has_repeats = False
            for i in range(len(password) - 3):
                if password[i] == password[i+1] == password[i+2] == 
password[i+3]:
                    has_repeats = True
                    break
            if has_repeats:
                reasons.append("repeats")
                score_val = 3
            else:
                score_val = 3
                # Check for sequences
                if length >= 16:
                    # Check for all 4 classes
                    if class_count == 4:
                        # Check for sequences
                        sequences = ["abcd", "dcba", "1234", "4321", "wxyz", 
"zyxw", "qwer", "rewq"]
                        for seq in sequences:
                            if seq in password:
                                reasons.append("sequence")
                                score_val = 4
                                break
                        # If no sequences, check if all conditions for 4 are met
                        if score_val == 4:
                            return (4, reasons)
                        else:
                            return (3, reasons)
                    else:
                        # Missing a class, but class_count is 3
                        for cls in ["lower", "upper", "digit", "symbol"]:
                            if cls not in classes:
                                reasons.append(f"missing-{cls}")
                        return (3, reasons)
                else:
                    # Length >=12 but <16, so score 3
                    return (3, reasons)
    else:
        # Length <8 already checked, so this shouldn't happen
        pass

    # For score 3, check if length >=12 and no repeats
    if score_val == 3:
        # Check for sequences if length >=16
        if length >= 16:
            # Check for all 4 classes
            if class_count == 4:
                # Check for sequences
                sequences = ["abcd", "dcba", "1234", "4321", "wxyz", "zyxw", 
"qwer", "rewq"]
                for seq in sequences:
                    if seq in password:
                        reasons.append("sequence")
                        score_val = 4
                        break
                # If no sequences, check if all conditions for 4 are met
                if score_val == 4:
                    return (4, reasons)
                else:
                    return (3, reasons)
            else:
                # Missing a class, but class_count is 3
                for cls in ["lower", "upper", "digit", "symbol"]:
                    if cls not in classes:
                        reasons.append(f"missing-{cls}")
                return (3, reasons)
        else:
            return (3, reasons)

    # For score 4, check if length >=16, all 4 classes, no repeats, no sequences
    if score_val == 4:
        return (4, reasons)

    return (score_val, reasons)

