import re

import numpy as np

from fractions import Fraction

from math import gcd

from functools import reduce



def balance(equation: str) -> tuple[list[int], list[int]]:

    """

    Take an unbalanced equation string like "H2 + O2 -> H2O".

    Return (lhs_coefficients, rhs_coefficients) as lists of POSITIVE integers

    in the smallest-integer form.



    Example:

        balance("H2 + O2 -> H2O") returns ([2, 1], [2])

        balance("CH4 + O2 -> CO2 + H2O") returns ([1, 2], [1, 2])

    """

    # Split equation into reactants and products

    if '->' not in equation:

        raise ValueError("Invalid equation format")

    

    lhs_str, rhs_str = equation.split('->')

    

    # Parse reactants and products

    lhs_compounds = [s.strip() for s in lhs_str.split('+') if s.strip()]

    rhs_compounds = [s.strip() for s in rhs_str.split('+') if s.strip()]

    

    # Get all unique elements

    elements = set()

    all_compounds = lhs_compounds + rhs_compounds

    

    for compound in all_compounds:

        elements.update(parse_compound(compound))

    

    elements = sorted(list(elements))

    

    # Build matrix of element counts

    matrix = []

    for element in elements:

        row = []

        # For each compound, count how many times this element appears

        for compound in lhs_compounds:

            count = count_element_in_compound(compound, element)

            row.append(count)

        for compound in rhs_compounds:

            count = count_element_in_compound(compound, element)

            row.append(-count)  # Negative because it's on the right side

        matrix.append(row)

    

    # Convert to numpy array

    A = np.array(matrix, dtype=int)

    

    # Find null space using SVD

    _, s, vh = np.linalg.svd(A)

    

    # Find the smallest singular value and corresponding vector

    tol = 1e-10

    rank = np.sum(s > tol)

    

    # If rank is less than number of columns, there's a non-trivial solution

    if rank < len(A[0]):

        # Get the null vector (last row of vh)

        null_vector = vh[-1]

        

        # Convert to positive integers

        # Find the least common multiple of denominators

        fractions = [Fraction(x).limit_denominator(1000000) for x in 
null_vector]

        denominators = [f.denominator for f in fractions]

        lcm_den = reduce(lambda a, b: a * b // gcd(a, b), denominators)

        

        # Scale to integers

        coefficients = [int(f.numerator * lcm_den // f.denominator) for f in 
fractions]

        

        # Make sure all coefficients are positive

        if all(c >= 0 for c in coefficients):

            # Find the smallest positive coefficient

            positive_coeffs = [c for c in coefficients if c > 0]

            if not positive_coeffs:

                raise ValueError("No valid solution found")

            

            # Find GCD of all coefficients

            common_gcd = reduce(gcd, positive_coeffs)

            

            # Normalize to smallest integers

            normalized_coeffs = [c // common_gcd for c in coefficients]

            

            # Separate into lhs and rhs

            lhs_coeffs = normalized_coeffs[:len(lhs_compounds)]

            rhs_coeffs = normalized_coeffs[len(lhs_compounds):]

            

            # Check if all coefficients are positive

            if all(c > 0 for c in lhs_coeffs + rhs_coeffs):

                return (lhs_coeffs, rhs_coeffs)

    

    # If we get here, the system might be inconsistent or we need a different 
approach

    # Let's try a more robust method using sympy for exact solving

    try:

        import sympy as sp

        

        # Create symbolic variables for coefficients

        coeffs = [sp.Symbol(f'c{i}') for i in range(len(all_compounds))]

        

        # Create equations for each element

        equations = []

        for element in elements:

            eq = 0

            for i, compound in enumerate(all_compounds):

                count = count_element_in_compound(compound, element)

                if i < len(lhs_compounds):

                    eq += coeffs[i] * count

                else:

                    eq -= coeffs[i] * count

            equations.append(sp.Eq(eq, 0))

        

        # Solve the system

        solution = sp.solve(equations, coeffs, dict=True)

        

        if not solution:

            raise ValueError("No solution found")

        

        # Get one solution

        sol = solution[0]

        

        # Convert to integers

        # Find lcm of denominators

        denominators = []

        for coeff in sol.values():

            if coeff.is_rational:

                denominators.append(coeff.q)

        

        if not denominators:

            raise ValueError("No valid solution found")

            

        lcm_den = reduce(lambda a, b: a * b // gcd(a, b), denominators)

        

        # Scale to integers

        integer_coeffs = []

        for i in range(len(all_compounds)):

            coeff = sol[coeffs[i]]

            integer_coeffs.append(int(coeff * lcm_den))

        

        # Separate into lhs and rhs

        lhs_coeffs = integer_coeffs[:len(lhs_compounds)]

        rhs_coeffs = integer_coeffs[len(lhs_compounds):]

        

        # Check if all coefficients are positive

        if all(c > 0 for c in lhs_coeffs + rhs_coeffs):

            # Reduce to smallest integers

            common_gcd = reduce(gcd, [c for c in lhs_coeffs + rhs_coeffs if c > 
0])

            lhs_coeffs = [c // common_gcd for c in lhs_coeffs]

            rhs_coeffs = [c // common_gcd for c in rhs_coeffs]

            

            return (lhs_coeffs, rhs_coeffs)

        

    except ImportError:

        pass

    

    raise ValueError("No valid solution found")



def parse_compound(compound):

    """Parse a compound string and return a set of element symbols."""

    elements = set()

    i = 0

    while i < len(compound):

        if compound[i].isupper():

            element = compound[i]

            i += 1

            while i < len(compound) and compound[i].islower():

                element += compound[i]

                i += 1

            elements.add(element)

        else:

            i += 1

    return elements



def count_element_in_compound(compound, element):

    """Count how many times an element appears in a compound."""

    count = 0

    i = 0

    while i < len(compound):

        if compound[i] == element[0]:

            # Check if it's the full element name

            if i + len(element) <= len(compound) and compound[i:i+len(element)] 
== element:

                # Count the subscript

                i += len(element)

                subscript = 0

                while i < len(compound) and compound[i].isdigit():

                    subscript = subscript * 10 + int(compound[i])

                    i += 1

                if subscript == 0:

                    subscript = 1

                count += subscript

            else:

                i += 1

        elif compound[i] == '(':

            # Handle parentheses

            j = i + 1

            paren_count = 1

            while j < len(compound) and paren_count > 0:

                if compound[j] == '(':

                    paren_count += 1

                elif compound[j] == ')':

                    paren_count -= 1

                j += 1

            

            # Get the content inside parentheses

            paren_content = compound[i+1:j-1]

            

            # Get the subscript after the parentheses

            subscript = 0

            k = j

            while k < len(compound) and compound[k].isdigit():

                subscript = subscript * 10 + int(compound[k])

                k += 1

            if subscript == 0:

                subscript = 1

            

            # Count elements in the parenthesized group

            group_count = 0

            for group_element in parse_compound(paren_content):

                group_count += count_element_in_compound(paren_content, 
group_element) * subscript

            

            count += group_count

            i = j

        else:

            i += 1

    return count

