import math



def sun_position(lat: float, lon: float, year: int, month: int, day: int,

                 hour: float = 12.0) -> tuple[float, float]:

    """Approximate sun altitude & azimuth (in degrees) for a UTC instant at 
(lat, lon).



    Inputs:

      lat, lon  — observer geographic coordinates, decimal degrees (lat positive
N, lon positive E)

      year/month/day  — UTC date

      hour  — UTC hour as a float (e.g. 12.5 for 12:30 UTC)



    Returns (altitude_deg, azimuth_deg) where:

      altitude is the angle of the sun above the horizon (negative below)

      azimuth is measured clockwise from north (0=N, 90=E, 180=S, 270=W), 
normalised to [0, 360)



    Use the simple NOAA-style algorithm:

      1. Compute Julian Day, then Julian Century (T = (JD - 2451545) / 36525).

      2. Mean longitude L0, mean anomaly M, equation of centre, true longitude.

      3. Obliquity epsilon ≈ 23.439 - 0.00000036 * (JD-2451545).

      4. Right ascension and declination from true longitude + obliquity.

      5. Local sidereal time and hour angle.

      6. Altitude/azimuth via standard spherical trig.



    Accuracy target: within ±1 degree of NOAA reference values."""

    

    # Convert to Julian Day

    if month <= 2:

        year -= 1

        month += 12

    

    a = year // 100

    b = 2 - a + (a // 4)

    

    jd = int(365.25 * (year + 4716)) + int(30.6001 * (month + 1)) + day + b - 
1524

    

    # Julian Century

    t = (jd - 2451545) / 36525

    

    # Mean longitude

    l0 = (280.46645 + 36000.76983 * t + 0.0003032 * t * t) % 360

    

    # Mean anomaly

    m = (357.52910 + 35999.05029 * t - 0.0001537 * t * t) % 360

    

    # Equation of center

    c = (1.914600 - 0.004817 * t - 0.000014 * t * t) * math.sin(math.radians(m))
+ \

        (0.019993 - 0.000101 * t) * math.sin(math.radians(2 * m)) + \

        0.000289 * math.sin(math.radians(3 * m))

    

    # True longitude

    theta = l0 + c

    

    # Obliquity of the ecliptic

    epsilon = 23.439 - 0.00000036 * (jd - 2451545)

    

    # Right ascension and declination

    alpha = math.degrees(math.atan2(math.cos(math.radians(epsilon)) * 
math.sin(math.radians(theta)), math.cos(math.radians(theta))))

    delta = math.degrees(math.asin(math.sin(math.radians(epsilon)) * 
math.sin(math.radians(theta))))

    

    # Local sidereal time

    lmst = (100.46 + 0.985647 * (jd - 2451545) + lon + 15 * hour) % 360

    

    # Hour angle

    ha = lmst - alpha

    

    # Altitude and azimuth

    altitude = math.degrees(math.asin(math.sin(math.radians(lat)) * 
math.sin(math.radians(delta)) + 

                                      math.cos(math.radians(lat)) * 
math.cos(math.radians(delta)) * math.cos(math.radians(ha))))

    

    azimuth = math.degrees(math.atan2(math.sin(math.radians(ha)), 

                                      math.cos(math.radians(ha)) * 
math.sin(math.radians(lat)) - 

                                      math.tan(math.radians(delta)) * 
math.cos(math.radians(lat))))

    

    # Normalize azimuth to [0, 360)

    azimuth = azimuth % 360

    

    return (altitude, azimuth)

