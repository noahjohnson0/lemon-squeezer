import heapq

def shortest_path(graph: dict[str, list[tuple[str, float]]], src: str, dst: str)
-> tuple[float, list[str]]:
    if src == dst:
        return (0.0, [src])
    
    distances = {node: float('inf') for node in graph}
    distances[src] = 0.0
    
    priority_queue = [(0.0, src, [src])]
    
    while priority_queue:
        current_dist, current_node, path = heapq.heappop(priority_queue)
        
        if current_node == dst:
            return (current_dist, path)
        
        if current_dist > distances[current_node]:
            continue
        
        for neighbor, weight in graph.get(current_node, []):
            new_dist = current_dist + weight
            if new_dist < distances[neighbor]:
                distances[neighbor] = new_dist
                heapq.heappush(priority_queue, (new_dist, neighbor, path + 
[neighbor]))
    
    return (float('inf'), [])

