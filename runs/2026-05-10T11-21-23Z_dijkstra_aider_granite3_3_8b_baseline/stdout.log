import heapq

def shortest_path(graph: dict[str, list[tuple[str, float]]], src: str, dst: str)
-> tuple[float, list[str]]:
    """Compute the shortest path from src to dst in a weighted directed graph.

    graph: {node_id: [(neighbour_id, weight), ...]} — edges have non-negative 
weights.
    Returns (total_distance, [src, ..., dst]).
    If no path exists, returns (float('inf'), []).
    If src == dst, returns (0.0, [src])."""

    # Initialize distances to all nodes as infinity and a path of empty list
    distances = {node: float('inf') for node in graph}
    distances[src] = 0.0
    previous_nodes = {node: None for node in graph}
    queue = [(0.0, [src])]

    while queue:
        current_distance, current_path = heapq.heappop(queue)

        if current_path[-1] == dst:
            return (current_distance, current_path)

        if current_distance > distances[current_path[-1]]:
            continue

        for neighbour, weight in graph[current_path[-1]]:
            distance = current_distance + weight

            if distance < distances[neighbour]:
                distances[neighbour] = distance
                heapq.heappush(queue, (distance, current_path + [neighbour]))
                previous_nodes[neighbour] = current_path[-1]

    return (float('inf'), [])
```

