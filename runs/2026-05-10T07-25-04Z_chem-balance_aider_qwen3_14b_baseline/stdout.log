import sympy
from math import gcd
from functools import reduce

def parse_formula(formula: str) -> dict[str, int]:
    elements = {}
    stack = []
    current_element = ''
    current_count = 0
    multiplier = 1
    i = 0
    while i < len(formula):
        char = formula[i]
        if char.isupper():
            if current_element:
                elements[current_element] = elements.get(current_element, 0) + 
current_count * multiplier
