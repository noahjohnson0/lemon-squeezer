def parse_formula(formula: str) -> dict[str, int]:
    elements = {}
    stack = []
    current_element = ''
    current_count = 0
    multiplier = 1
    i = 0
    while i < len(formula):
        char = formula[i]
        if char.isupper():
            if current_element:
                # Add the current element to the elements dict
                elements[current_element] = elements.get(current_element, 0) + 
current_count * multiplier
                current_element = ''
                current_count = 0
                multiplier = 1
            current_element += char
        elif char.islower():
            current_element += char
        elif char.isdigit():
            current_count = int(char)
            # Check if there's more digits
            j = i + 1
            while j < len(formula) and formula[j].isdigit():
                current_count = current_count * 10 + int(formula[j])
                j += 1
            i = j - 1
        elif char == '(':
            # Push current multiplier to stack
            stack.append(multiplier)
            multiplier = 1
        elif char == ')':
            # Pop multiplier from stack
            if stack:
                multiplier = stack.pop()
            else:
                raise ValueError("Unmatched parenthesis")
        i += 1
    # Handle the last element
    if current_element:
        elements[current_element] = elements.get(current_element, 0) + 
current_count * multiplier
    return elements

