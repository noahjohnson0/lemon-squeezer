#!/usr/bin/env python3
"""build-scores - bundle every run's per-check breakdown into ONE deployable file.

The dashboard's run drawer needs runs/<id>/score.json, but runs/ is not deployed
(it is gitignored and huge). This collects the breakdowns for every run in
runs.jsonl into dashboard-next/public/scores.json as {run_id: {checks,...}}, which
ships with the static site. Re-run after sweeps. Tolerant of the control-char
corruption the rubrics occasionally emit (same fallback as eval-rescore).
"""
from __future__ import annotations
import json, re
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
OUT = ROOT / "dashboard-next" / "public" / "scores.json"


def parse(text: str):
    m = re.search(r"\{[\s\S]+\}\s*$", text)
    if not m:
        return None
    blob = m.group(0)
    try:
        return json.loads(blob)
    except Exception:
        cleaned = re.sub(r"[\x00-\x08\x0b\x0c\x0e-\x1f]", "", blob).replace("\\", "")
        try:
            return json.loads(cleaned)
        except Exception:
            return None


def main() -> int:
    ids = []
    for line in (ROOT / "runs.jsonl").read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            ids.append(json.loads(line)["run_id"])
        except Exception:
            pass

    out = {}
    miss = 0
    for rid in ids:
        sp = ROOT / "runs" / rid / "score.json"
        if not sp.exists():
            miss += 1
            continue
        d = parse(sp.read_text(encoding="utf-8", errors="replace"))
        if not d or "checks" not in d:
            miss += 1
            continue
        # keep it compact: just what the drawer renders
        out[rid] = {
            "checks": [{"name": c.get("name"), "pass": c.get("pass"),
                        "weight": c.get("weight"), "note": (c.get("note") or "")[:200]}
                       for c in d.get("checks", [])],
            "gained": d.get("gained"), "total": d.get("total"), "score_pct": d.get("score_pct"),
        }
    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(json.dumps(out, separators=(",", ":")), encoding="utf-8")
    kb = OUT.stat().st_size / 1024
    print(f"wrote {OUT.relative_to(ROOT)}: {len(out)} breakdowns ({kb:.0f} KB), {miss} missing")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
