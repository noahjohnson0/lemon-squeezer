#!/usr/bin/env python3
"""cloud-report - aggregate the OpenRouter (host=openrouter) rows in runs.jsonl
into an honest leaderboard.

    python bin/cloud-report [--tag fable-hunt] [--json out.json] [--by-eval]
                            [--min-evals 8]

An "arm" is (model, harness) - a single open model OR a multi-model mix. With no
--tag, every openrouter row counts.

Statistics (why it's done this way)
-----------------------------------
Trials of the same eval are NOT independent observations - they share the task,
so naively treating every run as one IID sample understates uncertainty and lets
a couple of lucky runs on one easy eval dominate. So we aggregate in two stages:

  1. per eval: mean score over that eval's trials (failures count as 0).
  2. per arm:  the reported score is the mean of those per-eval means - every
               eval gets equal weight regardless of how many trials it happened
               to get.

The 95% interval is a CLUSTER bootstrap over evals (resample the per-eval means
with replacement, B times, take the 2.5/97.5 percentiles of the resampled arm
mean). That propagates "we only tested N evals" into the interval honestly. Arms
with fewer than --min-evals evals get no interval (reported as insufficient) and
sort to the bottom - a tiny suite can't earn a confident rank. Seeded, so the
report is reproducible.

Failures (score_pct not numeric, i.e. "?") are reported explicitly as
n_failed and counted as 0 in the eval mean - never silently dropped.
"""
from __future__ import annotations
import argparse, json, random, statistics, sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
BOOT_B = 2000
BOOT_SEED = 1234

# Evals that measure the scoring ENVIRONMENT, not the model (every arm gets the
# same uninformative score), so they are excluded from headline aggregates.
# port-scanner needs live sockets / a firewall-style timeout that don't behave on
# the Windows scoring box -> ~every arm lands at 20%. Re-include with --include-env.
EXCLUDED_EVALS = {"port-scanner"}


def load(tag=None, include_env=False):
    rows = []
    for line in (ROOT / "runs.jsonl").read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            r = json.loads(line)
        except Exception:
            continue
        if r.get("host") != "openrouter":
            continue
        if tag and r.get("tag") != tag:
            continue
        if not include_env and r.get("eval") in EXCLUDED_EVALS:
            continue
        s = r.get("score_pct")
        r["_score"] = float(s) if isinstance(s, (int, float)) else None
        rows.append(r)
    return rows


def _boot_ci(eval_means, rng, b=BOOT_B):
    """95% cluster bootstrap CI of the mean of per-eval means."""
    k = len(eval_means)
    if k < 2:
        return None, None
    samples = []
    for _ in range(b):
        resample = [eval_means[rng.randrange(k)] for _ in range(k)]
        samples.append(sum(resample) / k)
    samples.sort()
    lo = samples[int(0.025 * b)]
    hi = samples[min(b - 1, int(0.975 * b))]
    return round(lo, 1), round(hi, 1)


def agg(rows, min_evals):
    rng = random.Random(BOOT_SEED)
    arms = {}
    for r in rows:
        key = (r.get("model"), r.get("harness"))
        a = arms.setdefault(key, {"model": r.get("model"), "harness": r.get("harness"),
                                  "by_eval": {}, "cost": 0.0, "wall": [], "tin": 0, "tout": 0,
                                  "n_total": 0, "n_scored": 0, "n_failed": 0})
        a["n_total"] += 1
        a["cost"] += r.get("cost_usd", 0) or 0
        a["wall"].append(r.get("wall_seconds", 0) or 0)
        a["tin"] += r.get("tokens_in", 0) or 0
        a["tout"] += r.get("tokens_out", 0) or 0
        ev = r.get("eval")
        # a failed run scores 0 (it did not demonstrably succeed), and is also tallied.
        val = r["_score"] if r["_score"] is not None else 0.0
        a["by_eval"].setdefault(ev, []).append(val)
        if r["_score"] is None:
            a["n_failed"] += 1
        else:
            a["n_scored"] += 1

    out = []
    for a in arms.values():
        eval_means = [statistics.mean(v) for v in a["by_eval"].values()]
        n_evals = len(eval_means)
        mean = statistics.mean(eval_means) if eval_means else 0.0
        if n_evals >= min_evals:
            lo, hi = _boot_ci(eval_means, rng)
        else:
            lo = hi = None  # insufficient eval coverage to claim an interval
        out.append({
            "model": a["model"], "harness": a["harness"],
            "n_total": a["n_total"], "n_scored": a["n_scored"], "n_failed": a["n_failed"],
            "evals": n_evals,
            "mean_score": round(mean, 1),
            "ci_lo": lo, "ci_hi": hi,
            "total_cost": round(a["cost"], 4),
            "mean_cost": round(a["cost"] / a["n_total"], 5) if a["n_total"] else 0,
            "mean_wall_s": round(statistics.mean(a["wall"]), 1) if a["wall"] else 0,
            "tokens_in": a["tin"], "tokens_out": a["tout"],
            "score_per_dollar": round(mean / (100 * a["cost"] / a["n_total"]), 1) if a["cost"] else None,
        })
    # Sort: arms WITH an interval first (by lower bound), then insufficient ones by mean.
    out.sort(key=lambda x: (x["ci_lo"] is None, -(x["ci_lo"] if x["ci_lo"] is not None else x["mean_score"]),
                            x["mean_cost"]))
    return out


def by_eval(rows):
    evals = sorted({r.get("eval") for r in rows})
    arms = sorted({(r.get("model"), r.get("harness")) for r in rows})
    cell = {}
    for r in rows:
        val = r["_score"] if r["_score"] is not None else 0.0
        cell.setdefault((r.get("model"), r.get("harness")), {}).setdefault(r.get("eval"), []).append(val)
    return evals, arms, cell


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--tag", default=None)
    ap.add_argument("--json", default=None, help="also write the leaderboard to this JSON path")
    ap.add_argument("--by-eval", action="store_true")
    ap.add_argument("--min-evals", type=int, default=8,
                    help="arms with fewer scored evals than this get no CI and sort last")
    ap.add_argument("--include-env", action="store_true",
                    help=f"include environment-dependent evals ({', '.join(sorted(EXCLUDED_EVALS))})")
    a = ap.parse_args()

    rows = load(a.tag, include_env=a.include_env)
    if not rows:
        print("no openrouter rows" + (f" for tag={a.tag}" if a.tag else ""), file=sys.stderr)
        return 1
    board = agg(rows, a.min_evals)

    total_cost = sum(r.get("cost_usd", 0) or 0 for r in rows)
    n_failed = sum(1 for r in rows if r["_score"] is None)
    print(f"# {len(rows)} openrouter runs" + (f" (tag={a.tag})" if a.tag else "") +
          f", {len({r['eval'] for r in rows})} evals, {n_failed} unscored, ${total_cost:.4f} spent total\n")
    print("score = mean of per-eval means; 95% CI = cluster bootstrap over evals; "
          f"arms with <{a.min_evals} evals shown as 'insf' and sorted last\n")
    print(f"{'ARM':24} {'harness':15} {'ev':>3} {'n':>4} {'fail':>4} {'mean%':>6} {'95% CI':>13} {'$/run':>8} {'/$':>5} {'wall':>5}")
    print("-" * 100)
    for r in board:
        spd = "" if r["score_per_dollar"] is None else f"{r['score_per_dollar']:.0f}"
        ci = "insf" if r["ci_lo"] is None else f"[{r['ci_lo']:.0f}-{r['ci_hi']:.0f}]"
        print(f"{(r['model'] or '?')[:24]:24} {(r['harness'] or '')[:15]:15} {r['evals']:>3} "
              f"{r['n_total']:>4} {r['n_failed']:>4} {r['mean_score']:>6.1f} {ci:>13} "
              f"{r['mean_cost']:>8.5f} {spd:>5} {r['mean_wall_s']:>4.0f}s")

    if a.by_eval:
        evals, arms, cell = by_eval(rows)
        print("\n## per-eval mean score (rows=arm, cols=eval; failures=0)\n")
        hdr = "ARM".ljust(26) + "".join(e[:7].rjust(8) for e in evals)
        print(hdr)
        for m, h in arms:
            line = f"{(m or '?')[:26]:26}"
            for e in evals:
                vs = cell.get((m, h), {}).get(e)
                line += (f"{statistics.mean(vs):>8.0f}" if vs else f"{'·':>8}")
            print(line)

    if a.json:
        Path(a.json).write_text(json.dumps({
            "generated_tag": a.tag, "n_runs": len(rows), "n_failed": n_failed,
            "total_cost": round(total_cost, 4), "min_evals": a.min_evals,
            "leaderboard": board,
        }, indent=2), encoding="utf-8")
        print(f"\nwrote {a.json}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
