#!/usr/bin/env python3
"""cloud-report - aggregate the OpenRouter (host=openrouter) rows in runs.jsonl
into a leaderboard: per-arm mean score, total/mean cost, mean latency, and the
score-per-dollar "value" that's the whole point of the Fable-destroyer hunt.

    python bin/cloud-report [--tag fable-hunt] [--json out.json] [--by-eval]

An "arm" is (model, harness) - a single open model OR a multi-model mix. With no
--tag, every openrouter row counts.
"""
from __future__ import annotations
import argparse, json, statistics, sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent


def load(tag=None):
    rows = []
    for line in (ROOT / "runs.jsonl").read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            r = json.loads(line)
        except Exception:
            continue
        if r.get("host") != "openrouter":
            continue
        if tag and r.get("tag") != tag:
            continue
        # numeric score only
        s = r.get("score_pct")
        r["_score"] = float(s) if isinstance(s, (int, float)) else (float(s) if str(s).replace(".", "", 1).isdigit() else None)
        rows.append(r)
    return rows


def agg(rows):
    arms = {}
    for r in rows:
        key = (r.get("model"), r.get("harness"))
        a = arms.setdefault(key, {"model": r.get("model"), "harness": r.get("harness"),
                                  "scores": [], "cost": 0.0, "wall": [], "tin": 0, "tout": 0,
                                  "evals": set(), "n": 0, "fails": 0})
        a["n"] += 1
        a["cost"] += r.get("cost_usd", 0) or 0
        a["wall"].append(r.get("wall_seconds", 0) or 0)
        a["tin"] += r.get("tokens_in", 0) or 0
        a["tout"] += r.get("tokens_out", 0) or 0
        a["evals"].add(r.get("eval"))
        if r["_score"] is None:
            a["fails"] += 1
        else:
            a["scores"].append(r["_score"])
    out = []
    for a in arms.values():
        sc = a["scores"]
        mean = statistics.mean(sc) if sc else 0.0
        # 95% CI on the mean (scores are continuous 0-100, so SEM-based, not Wilson),
        # clamped to [0,100]. Sort by the lower bound so a lucky 1-run 100% can't top.
        if len(sc) >= 2:
            sem = statistics.stdev(sc) / (len(sc) ** 0.5)
            half = 1.96 * sem
        else:
            half = 50.0  # n<2: huge uncertainty, parks it low
        lo = max(0.0, mean - half)
        hi = min(100.0, mean + half)
        out.append({
            "model": a["model"], "harness": a["harness"], "n": a["n"],
            "evals": len(a["evals"]),
            "mean_score": round(mean, 1),
            "ci_lo": round(lo, 1), "ci_hi": round(hi, 1),
            "total_cost": round(a["cost"], 4),
            "mean_cost": round(a["cost"] / a["n"], 5) if a["n"] else 0,
            "mean_wall_s": round(statistics.mean(a["wall"]), 1) if a["wall"] else 0,
            "tokens_in": a["tin"], "tokens_out": a["tout"],
            "score_per_cent": round(mean / (100 * a["cost"] / a["n"]), 1) if a["cost"] else None,
            "parse_fails": a["fails"],
        })
    out.sort(key=lambda x: (-x["ci_lo"], x["mean_cost"]))
    return out


def by_eval(rows):
    evals = sorted({r.get("eval") for r in rows})
    arms = sorted({(r.get("model"), r.get("harness")) for r in rows})
    cell = {}
    for r in rows:
        if r["_score"] is None:
            continue
        cell.setdefault((r.get("model"), r.get("harness")), {}).setdefault(r.get("eval"), []).append(r["_score"])
    return evals, arms, cell


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--tag", default=None)
    ap.add_argument("--json", default=None, help="also write the leaderboard to this JSON path")
    ap.add_argument("--by-eval", action="store_true")
    a = ap.parse_args()

    rows = load(a.tag)
    if not rows:
        print("no openrouter rows" + (f" for tag={a.tag}" if a.tag else ""), file=sys.stderr)
        return 1
    board = agg(rows)

    total_cost = sum(r.get("cost_usd", 0) or 0 for r in rows)
    print(f"# {len(rows)} openrouter runs" + (f" (tag={a.tag})" if a.tag else "") +
          f", {len({r['eval'] for r in rows})} evals, ${total_cost:.4f} spent total\n")
    print("ranked by lower bound of the 95% CI (n<3 flagged *; n<2 parked low)\n")
    print(f"{'ARM':24} {'harness':15} {'n':>3} {'mean%':>6} {'95% CI':>13} {'$/run':>8} {'$/$':>5} {'wall':>5}")
    print("-" * 88)
    for r in board:
        spc = "" if r["score_per_cent"] is None else f"{r['score_per_cent']:.0f}"
        flag = "*" if r["n"] < 3 else " "
        ci = f"[{r['ci_lo']:.0f}-{r['ci_hi']:.0f}]"
        print(f"{(r['model'] or '?')[:24]:24} {(r['harness'] or '')[:15]:15} {r['n']:>2}{flag} "
              f"{r['mean_score']:>6.1f} {ci:>13} {r['mean_cost']:>8.5f} {spc:>5} {r['mean_wall_s']:>4.0f}s")

    if a.by_eval:
        evals, arms, cell = by_eval(rows)
        print("\n## per-eval mean score (rows=arm, cols=eval)\n")
        hdr = "ARM".ljust(26) + "".join(e[:7].rjust(8) for e in evals)
        print(hdr)
        for m, h in arms:
            line = f"{(m or '?')[:26]:26}"
            for e in evals:
                vs = cell.get((m, h), {}).get(e)
                line += (f"{statistics.mean(vs):>8.0f}" if vs else f"{'·':>8}")
            print(line)

    if a.json:
        Path(a.json).write_text(json.dumps({
            "generated_tag": a.tag, "n_runs": len(rows), "total_cost": round(total_cost, 4),
            "leaderboard": board,
        }, indent=2), encoding="utf-8")
        print(f"\nwrote {a.json}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
