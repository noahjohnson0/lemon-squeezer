#!/usr/bin/env bash
# eval-run <harness> <eval-name> <model> <tag> [-- harness-flags...]
# Generic runner. Dispatches to bin/harnesses/<harness>.sh for the actual invocation.
set -euo pipefail
[ -f "$HOME/.config/lemon-squeezer.env" ] && . "$HOME/.config/lemon-squeezer.env"

LSQ_ROOT="${HOME}/repos/lemon-squeezer"

# --host <name> selects a host profile from hosts/<name>.env (sourced before
# anything else). Profiles set OLLAMA_API_BASE / SAMPLER_SSH_TARGET / LEMON_HOST
# so a single eval-run invocation can target the M4 Max, the 4070, or whatever
# else without leaking config into the repo.
if [[ "${1:-}" == "--host" ]]; then
  HOST_NAME="${2:?--host requires a profile name}"
  HOST_FILE="$LSQ_ROOT/hosts/${HOST_NAME}.env"
  [[ -f "$HOST_FILE" ]] || { echo "no host profile: $HOST_FILE" >&2; exit 1; }
  . "$HOST_FILE"
  shift 2
fi
# Default host name if nothing set it (legacy runs were all 4070).
: "${LEMON_HOST:=4070}"

# Parse the args eagerly so we can register a pending entry before grabbing the lock.
# (Reparsed below for the actual run.)
PRE_HARNESS="${1:-?}"; PRE_EVAL="${2:-?}"; PRE_MODEL="${3:-?}"; PRE_TAG="${4:-?}"

# Register this invocation in pending/ so the dashboard shows queued runs.
PENDING_DIR="$LSQ_ROOT/pending/$$"
mkdir -p "$PENDING_DIR"
cat > "$PENDING_DIR/info" <<PEND
harness=$PRE_HARNESS
eval=$PRE_EVAL
model=$PRE_MODEL
tag=$PRE_TAG
queued_ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
queued_epoch=$(date +%s)
pid=$$
PEND

# ────────────────────────── GPU serialization lock ──────────────────────────
# The whole point of this benchmark is reproducible wall-clock + telemetry.
# Concurrent runs against the same Ollama host destroy that — Ollama queues
# requests, so wall_seconds includes wait-time and the GPU sampler captures
# whichever run happens to be active at sample time, not necessarily ours.
#
# We use an atomic mkdir-based lock: only one eval-run holds the GPU at a time.
# Multiple invocations queue automatically. Set LEMON_NO_LOCK=1 to bypass.
LOCK="$LSQ_ROOT/.gpu.lock"
if [[ "${LEMON_NO_LOCK:-0}" != "1" ]]; then
  trap 'rm -rf "$PENDING_DIR" "$LOCK"' EXIT INT TERM
  WAITED=0
  while ! mkdir "$LOCK" 2>/dev/null; do
    if (( WAITED == 0 )); then
      echo "⏳ another eval-run holds the GPU lock; queueing…"
      WAITED=1
    fi
    if [[ -f "$LOCK/owner.pid" ]]; then
      OWNER=$(cat "$LOCK/owner.pid" 2>/dev/null || echo 0)
      if (( OWNER > 0 )) && ! kill -0 "$OWNER" 2>/dev/null; then
        echo "  lock owner pid $OWNER is dead; reclaiming"
        rm -rf "$LOCK"
        continue
      fi
    fi
    sleep 2
  done
  echo "$$" > "$LOCK/owner.pid"
fi
# We have the lock — promote pending → running. The pending entry is removed
# now, but the run_dir + .sampling flag will surface us under "Running" instead.
rm -rf "$PENDING_DIR"

HARNESS="${1:?usage: eval-run <harness> <eval> <model> <tag> [-- flags...]}"
EVAL="${2:?eval required}"
MODEL="${3:?model required}"
TAG="${4:?tag required}"
shift 4
if [[ "${1:-}" == "--" ]]; then shift; fi
EXTRA_FLAGS=("$@")

ROOT="$HOME/repos/lemon-squeezer"
EVAL_DIR="$ROOT/evals/$EVAL"
HARNESS_SCRIPT="$ROOT/bin/harnesses/$HARNESS.sh"
[[ -d "$EVAL_DIR" ]] || { echo "no such eval: $EVAL_DIR" >&2; exit 1; }
[[ -f "$HARNESS_SCRIPT" ]] || { echo "no such harness: $HARNESS_SCRIPT" >&2; exit 1; }

PROMPT_FILE="$EVAL_DIR/prompt.md"
RUBRIC="$EVAL_DIR/rubric.sh"
SETUP="$EVAL_DIR/setup.sh"

TS="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
SAFE_MODEL="${MODEL//[^A-Za-z0-9]/_}"
RUN_ID="${TS}_${EVAL}_${HARNESS}_${SAFE_MODEL}_${TAG}"
RUN_DIR="$ROOT/runs/$RUN_ID"
WS="$RUN_DIR/workspace"
mkdir -p "$WS"

# Stash original (un-sanitised) metadata so the inflight watcher can show real names
printf '%s' "$MODEL" > "$RUN_DIR/.model"
printf '%s' "$TAG"   > "$RUN_DIR/.tag"

echo "▶ run_id:  $RUN_ID"
echo "  harness: $HARNESS"
echo "  eval:    $EVAL  | model: $MODEL  | tag: $TAG"
echo "  flags:   ${EXTRA_FLAGS[*]:-(none)}"
echo

# Optional setup: drop starter files into the workspace before the harness runs
if [[ -f "$SETUP" ]]; then
  ( cd "$WS" && bash "$SETUP" "$WS" "$EVAL_DIR" )
fi

START=$(date +%s)

# Start hardware-telemetry sampler (best-effort; doesn't block the run if it fails)
SAMPLER_PID=""
if [[ -x "$ROOT/bin/sampler" ]]; then
  SAMPLER_PID="$("$ROOT/bin/sampler" start "$RUN_DIR" 2>/dev/null || true)"
fi

# Per-run wall-clock timeout (default 10 min). Override via $LEMON_RUN_TIMEOUT (seconds).
# Pipelines like squeezer-critique/squeezer-ensemble can take longer; bump for those.
RUN_TIMEOUT="${LEMON_RUN_TIMEOUT:-600}"
case "$HARNESS" in
  squeezer-critique|squeezer-ensemble) RUN_TIMEOUT="${LEMON_PIPELINE_TIMEOUT:-1800}" ;;
esac
TIMEOUT_BIN="$(command -v gtimeout || command -v timeout || echo '')"

set +e
if [[ -n "$TIMEOUT_BIN" ]]; then
  ( source "$HARNESS_SCRIPT" \
    && "$TIMEOUT_BIN" --foreground "$RUN_TIMEOUT" bash -c '
        source "$1"
        harness_run "$2" "$3" "$4" "$5" "${@:6}"
      ' _ "$HARNESS_SCRIPT" "$WS" "$PROMPT_FILE" "$MODEL" "$RUN_DIR" \
        ${EXTRA_FLAGS[@]+"${EXTRA_FLAGS[@]}"} \
  ) >"$RUN_DIR/stdout.log" 2>"$RUN_DIR/stderr.log"
else
  ( source "$HARNESS_SCRIPT" \
    && harness_run "$WS" "$PROMPT_FILE" "$MODEL" "$RUN_DIR" \
         ${EXTRA_FLAGS[@]+"${EXTRA_FLAGS[@]}"} \
    ) >"$RUN_DIR/stdout.log" 2>"$RUN_DIR/stderr.log"
fi
EXIT=$?
# Exit 124 = timeout
if [[ "$EXIT" == "124" ]]; then
  echo "[eval-run] HARD TIMEOUT after ${RUN_TIMEOUT}s — killing harness" >> "$RUN_DIR/stderr.log"
fi
set -e
WALL=$(( $(date +%s) - START ))

# Harness should have populated tokens_in/tokens_out/tool_calls files if available
TOKENS_IN=$(cat "$RUN_DIR/tokens_in" 2>/dev/null || echo 0)
TOKENS_OUT=$(cat "$RUN_DIR/tokens_out" 2>/dev/null || echo 0)
TOOL_CALLS=$(cat "$RUN_DIR/tool_calls" 2>/dev/null || echo 0)

# Score
SCORE="?"
if [[ -f "$RUBRIC" ]]; then
  bash "$RUBRIC" "$WS" > "$RUN_DIR/score.json" 2>"$RUN_DIR/score.err" || true
  SCORE=$(python3 -c "import json; print(json.load(open('$RUN_DIR/score.json')).get('score_pct','?'))" 2>/dev/null || echo "?")
fi

# Meta
python3 - <<PY > "$RUN_DIR/meta.json"
import json
print(json.dumps({
  "run_id": "$RUN_ID",
  "ts": "$TS",
  "eval": "$EVAL",
  "harness": "$HARNESS",
  "model": "$MODEL",
  "tag": "$TAG",
  "host": "$LEMON_HOST",
  "extra_flags": $(printf '%s\n' ${EXTRA_FLAGS[@]+"${EXTRA_FLAGS[@]}"} | python3 -c "import sys,json; print(json.dumps([l.rstrip() for l in sys.stdin if l.strip()]))"),
  "exit_code": $EXIT,
  "wall_seconds": $WALL,
  "tokens_in": $TOKENS_IN,
  "tokens_out": $TOKENS_OUT,
  "tool_calls": $TOOL_CALLS,
  "score_pct": "$SCORE"
}, indent=2))
PY

# Stop sampler AFTER meta.json is initialized — sampler appends telemetry to it
if [[ -n "$SAMPLER_PID" && -x "$ROOT/bin/sampler" ]]; then
  "$ROOT/bin/sampler" stop "$RUN_DIR" "$SAMPLER_PID" >/dev/null 2>&1 || true
fi

cat "$RUN_DIR/meta.json" | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))" >> "$ROOT/runs.jsonl"

# Auto-update CSV + RUNS.md after each run
"$ROOT/bin/eval-export" >/dev/null 2>&1 || true

echo "✓ ${WALL}s | exit=$EXIT | tok in/out=$TOKENS_IN/$TOKENS_OUT | tools=$TOOL_CALLS | score=${SCORE}%"
echo "  $RUN_DIR"
