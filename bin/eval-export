#!/usr/bin/env bash
# Read all runs, write CSV + Markdown tables + a per-eval/per-model leaderboard.
set -euo pipefail
ROOT="$HOME/lemon-squeezer"

# Always rebuild runs.jsonl from per-run meta.json (source of truth)
: > "$ROOT/runs.jsonl"
for d in "$ROOT"/runs/*/; do
  [[ -f "$d/meta.json" ]] || continue
  python3 -c "import json,sys; print(json.dumps(json.load(open('$d/meta.json'))))" >> "$ROOT/runs.jsonl"
done

python3 - "$ROOT" <<'PY'
import csv, json, os, sys
from collections import defaultdict

root = sys.argv[1]
runs = []
with open(f"{root}/runs.jsonl") as f:
    for line in f:
        line = line.strip()
        if line:
            runs.append(json.loads(line))
runs.sort(key=lambda r: r.get('ts',''))

# CSV
with open(f"{root}/runs.csv", "w", newline="") as f:
    w = csv.writer(f)
    w.writerow(["run_id","ts","eval","harness","model","tag","wall_s","tok_in","tok_out","tools","exit","score_pct"])
    for r in runs:
        w.writerow([
            r.get("run_id",""), r.get("ts",""), r.get("eval",""),
            r.get("harness","pi"), r.get("model",""), r.get("tag",""),
            r.get("wall_seconds",""), r.get("tokens_in",""), r.get("tokens_out",""),
            r.get("tool_calls",""), r.get("exit_code",""), r.get("score_pct",""),
        ])

# Markdown: full chronological table + leaderboard per eval
md = ["# Pi-Evals Run Log", "", f"_{len(runs)} runs total. Auto-generated by pi-eval-export._", ""]

# Leaderboard: best score per (eval, harness, model) — keep latest tag info
md.append("## Leaderboard — best score per (eval × harness × model)\n")
md.append("| eval | harness | model | best % | tag (best) | wall_s | tok_in/out |")
md.append("|---|---|---|---:|---|---:|---|")
best = {}
for r in runs:
    try: r['score_pct'] = int(r['score_pct'])
    except (ValueError, TypeError, KeyError): continue
    key = (r['eval'], r.get('harness','pi'), r['model'])
    if key not in best or r['score_pct'] > best[key]['score_pct']:
        best[key] = r
for (e,h,m), r in sorted(best.items()):
    md.append(f"| {e} | {h} | {m} | {r['score_pct']} | {r.get('tag','')} | {r.get('wall_seconds','')} | {r.get('tokens_in','')}/{r.get('tokens_out','')} |")

md.append("\n## Per-eval summary (best harness × model)\n")
per_eval = defaultdict(list)
for (e,h,m), r in best.items():
    per_eval[e].append(r)
for e in sorted(per_eval):
    md.append(f"### `{e}`")
    md.append("| harness | model | tag | score % | wall_s |")
    md.append("|---|---|---|---:|---:|")
    for r in sorted(per_eval[e], key=lambda x: -x['score_pct']):
        md.append(f"| {r.get('harness','pi')} | {r['model']} | {r.get('tag','')} | {r['score_pct']} | {r.get('wall_seconds','')} |")
    md.append("")

md.append("## Full chronological log\n")
md.append("| ts | eval | harness | model | tag | wall_s | tok_in | tok_out | tools | score |")
md.append("|---|---|---|---|---|---:|---:|---:|---:|---:|")
for r in runs:
    md.append("| {ts} | {eval} | {harness} | {model} | {tag} | {wall} | {ti} | {to} | {tc} | {sc} |".format(
        ts=r.get('ts',''), eval=r.get('eval',''), harness=r.get('harness','pi'),
        model=r.get('model',''), tag=r.get('tag',''),
        wall=r.get('wall_seconds',''), ti=r.get('tokens_in',''), to=r.get('tokens_out',''),
        tc=r.get('tool_calls',''), sc=r.get('score_pct',''),
    ))

with open(f"{root}/RUNS.md", "w") as f:
    f.write("\n".join(md) + "\n")

print(f"wrote {len(runs)} runs → {root}/runs.csv, {root}/RUNS.md")
PY
