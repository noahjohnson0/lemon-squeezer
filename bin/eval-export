#!/usr/bin/env bash
# Read all runs, write CSV + Markdown tables + a per-eval/per-model leaderboard.
set -euo pipefail
ROOT="$HOME/repos/lemon-squeezer"

# Always rebuild runs.jsonl from per-run meta.json (source of truth)
: > "$ROOT/runs.jsonl"
for d in "$ROOT"/runs/*/; do
  [[ -f "$d/meta.json" ]] || continue
  python3 -c "import json,sys; print(json.dumps(json.load(open('$d/meta.json'))))" >> "$ROOT/runs.jsonl"
done

python3 - "$ROOT" <<'PY'
import csv, json, os, sys
from collections import defaultdict

root = sys.argv[1]
runs = []
with open(f"{root}/runs.jsonl") as f:
    for line in f:
        line = line.strip()
        if line:
            runs.append(json.loads(line))
runs.sort(key=lambda r: r.get('ts',''))

# CSV
with open(f"{root}/runs.csv", "w", newline="") as f:
    w = csv.writer(f)
    w.writerow(["run_id","ts","eval","harness","model","tag","wall_s","tok_in","tok_out","tools","exit","score_pct"])
    for r in runs:
        w.writerow([
            r.get("run_id",""), r.get("ts",""), r.get("eval",""),
            r.get("harness","pi"), r.get("model",""), r.get("tag",""),
            r.get("wall_seconds",""), r.get("tokens_in",""), r.get("tokens_out",""),
            r.get("tool_calls",""), r.get("exit_code",""), r.get("score_pct",""),
        ])

# Markdown: full chronological table + leaderboard per eval
md = ["# Pi-Evals Run Log", "", f"_{len(runs)} runs total. Auto-generated by pi-eval-export._", ""]

# Leaderboard: best score per (eval, harness, model) - keep latest tag info
md.append("## Leaderboard - best score per (eval × harness × model)\n")
md.append("| eval | harness | model | best % | tag (best) | wall_s | tok_in/out |")
md.append("|---|---|---|---:|---|---:|---|")
best = {}
for r in runs:
    try: r['score_pct'] = int(r['score_pct'])
    except (ValueError, TypeError, KeyError): continue
    key = (r['eval'], r.get('harness','pi'), r['model'])
    if key not in best or r['score_pct'] > best[key]['score_pct']:
        best[key] = r
for (e,h,m), r in sorted(best.items()):
    md.append(f"| {e} | {h} | {m} | {r['score_pct']} | {r.get('tag','')} | {r.get('wall_seconds','')} | {r.get('tokens_in','')}/{r.get('tokens_out','')} |")

md.append("\n## Per-eval summary (best harness × model)\n")
per_eval = defaultdict(list)
for (e,h,m), r in best.items():
    per_eval[e].append(r)
for e in sorted(per_eval):
    md.append(f"### `{e}`")
    md.append("| harness | model | tag | score % | wall_s |")
    md.append("|---|---|---|---:|---:|")
    for r in sorted(per_eval[e], key=lambda x: -x['score_pct']):
        md.append(f"| {r.get('harness','pi')} | {r['model']} | {r.get('tag','')} | {r['score_pct']} | {r.get('wall_seconds','')} |")
    md.append("")

md.append("## Full chronological log\n")
md.append("| ts | eval | harness | model | tag | wall_s | tok_in | tok_out | tools | score |")
md.append("|---|---|---|---|---|---:|---:|---:|---:|---:|")
for r in runs:
    md.append("| {ts} | {eval} | {harness} | {model} | {tag} | {wall} | {ti} | {to} | {tc} | {sc} |".format(
        ts=r.get('ts',''), eval=r.get('eval',''), harness=r.get('harness','pi'),
        model=r.get('model',''), tag=r.get('tag',''),
        wall=r.get('wall_seconds',''), ti=r.get('tokens_in',''), to=r.get('tokens_out',''),
        tc=r.get('tool_calls',''), sc=r.get('score_pct',''),
    ))

with open(f"{root}/RUNS.md", "w") as f:
    f.write("\n".join(md) + "\n")

# Regenerate dashboard-next/public/findings.md so the live site has fresh insights.
try:
    from collections import defaultdict
    findings = []
    findings.append("# 🍋 Findings\n")
    findings.append(f"_{len(runs)} runs · {len(set(r['eval'] for r in runs))} evals · "
                    f"{len(set(r.get('harness','pi') for r in runs))} harnesses · "
                    f"{len(set(r['model'] for r in runs))} models. Auto-generated._\n")
    bestmap = {}
    for r in runs:
        if not isinstance(r['score_pct'], int): continue
        k = (r['eval'], r.get('harness','pi'), r['model'])
        if k not in bestmap or bestmap[k]['score_pct'] < r['score_pct']:
            bestmap[k] = r
    def avg(xs): return sum(xs)/len(xs) if xs else 0
    findings.append("## Harness scoreboard\n")
    findings.append("| harness | avg | cells |")
    findings.append("|---|---:|---:|")
    hav = []
    for h in sorted({k[1] for k in bestmap}):
        cells = [(k,v) for k,v in bestmap.items() if k[1] == h]
        if cells: hav.append((h, avg([v['score_pct'] for _,v in cells]), len(cells)))
    for h,a,n in sorted(hav, key=lambda x: -x[1]):
        findings.append(f"| `{h}` | **{a:.1f}** | {n} |")
    findings.append("")
    findings.append("## Model scoreboard\n")
    findings.append("| model | avg | cells |")
    findings.append("|---|---:|---:|")
    mav = []
    for m in sorted({k[2] for k in bestmap}):
        cells = [(k,v) for k,v in bestmap.items() if k[2] == m]
        if cells: mav.append((m, avg([v['score_pct'] for _,v in cells]), len(cells)))
    for m,a,n in sorted(mav, key=lambda x: -x[1]):
        findings.append(f"| `{m}` | **{a:.1f}** | {n} |")
    findings.append("")
    # Multi-step vs single-pass
    findings.append("## Alchemy: multi-step vs single-pass\n")
    SINGLE = {'squeezer','aider','pi'}
    MULTI = {'squeezer-tdd','squeezer-verify','squeezer-critique','squeezer-architect','squeezer-ensemble'}
    rows = []
    for (e, m) in {(k[0], k[2]) for k in bestmap}:
        bs = max([bestmap[(e,h,m)]['score_pct'] for h in SINGLE if (e,h,m) in bestmap], default=None)
        bm = max([bestmap[(e,h,m)]['score_pct'] for h in MULTI  if (e,h,m) in bestmap], default=None)
        if bs is not None and bm is not None: rows.append((e, m, bs, bm, bm - bs))
    rows.sort(key=lambda x: -x[4])
    findings.append("| eval | model | single-pass | multi-step | Δ |")
    findings.append("|---|---|---:|---:|---:|")
    for e,m,s,p,d in rows[:15]:
        findings.append(f"| `{e}` | `{m}` | {s}% | {p}% | **{d:+d}** |")
    if rows:
        positive = sum(1 for r in rows if r[4] > 0)
        mean_d = avg([r[4] for r in rows])
        findings.append(f"\n_Across {len(rows)} (eval × model) pairs with both single-pass and multi-step: "
                        f"{positive} improved with a pipeline. Mean delta = **{mean_d:+.1f} pts**._\n")
    findings_path = os.path.join(os.path.dirname(root), os.path.basename(root), "dashboard-next/public/findings.md")
    findings_path = f"{root}/dashboard-next/public/findings.md"
    if os.path.isdir(os.path.dirname(findings_path)):
        with open(findings_path, "w") as f:
            f.write("\n".join(findings) + "\n")
except Exception as e:
    pass  # non-fatal

print(f"wrote {len(runs)} runs → {root}/runs.csv, {root}/RUNS.md")
PY
