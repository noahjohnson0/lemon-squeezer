# RTX 4070 profile — Windows host on the LAN, remote Ollama, full nvidia-smi telemetry.
# DO NOT commit your specific OLLAMA_API_BASE / SAMPLER_SSH_TARGET — keep those in
# ~/.config/lemon-squeezer.env (already gitignored). This file just sets the host name.
export LEMON_HOST=4070
# Inherit from ~/.config/lemon-squeezer.env if present (contains your IP + ssh user).
[ -f "$HOME/.config/lemon-squeezer.env" ] && . "$HOME/.config/lemon-squeezer.env"
