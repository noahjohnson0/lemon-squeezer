# M4 Max profile — Apple Silicon, local Ollama, no remote GPU sampling.
# Sourced by `bin/eval-run --host m4max` or by setting LEMON_HOST=m4max.
export LEMON_HOST=m4max
export OLLAMA_API_BASE=http://localhost:11434
# No SSH target — the sampler will capture host_load1 only (no nvidia-smi on Mac).
export SAMPLER_SSH_TARGET=
